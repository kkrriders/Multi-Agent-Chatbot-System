# Multi-Agent Chatbot System Configuration
# Copy this file to .env and fill in ALL required values before starting.

# ── Required secrets ──────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
AGENT_SHARED_SECRET=
MONGODB_URI=mongodb://localhost:27017/multi-agent-chatbot
FRONTEND_URL=http://localhost:3002

# ── Optional ──────────────────────────────────────────────────────────────────
# Redis for persistent rate limiting (falls back to in-memory if not set)
REDIS_URL=redis://localhost:6379

# ── Manager Configuration ─────────────────────────────────────────────────────
# Manager Configuration
MANAGER_PORT=3000
MANAGER_MODEL=llama3:latest

# Agent Ports (3001 reserved for frontend)
AGENT_1_PORT=3005
AGENT_2_PORT=3006
AGENT_3_PORT=3007
AGENT_4_PORT=3008

# Agent Models
AGENT_1_MODEL=llama3:latest
AGENT_2_MODEL=mistral:latest
AGENT_3_MODEL=phi3:latest
AGENT_4_MODEL=qwen2.5-coder:latest

# Ollama Configuration
# For local setup: http://localhost:11434/api
# For WSL2 with Windows Ollama: http://172.18.224.1:11434/api
OLLAMA_API_BASE=http://localhost:11434/api

# Timeout Settings (in milliseconds)
OLLAMA_TIMEOUT=180000
AGENT_TIMEOUT=180000
REQUEST_TIMEOUT=180000

# WebSocket Settings
WEBSOCKET_PING_TIMEOUT=180000
WEBSOCKET_PING_INTERVAL=25000

# Logging Configuration
LOG_LEVEL=info
LOG_DIR=./logs

# Performance Monitoring
PERFORMANCE_MONITOR_PORT=3099