# Multi-Agent Chatbot System — Environment Configuration
# Copy to .env and fill in required values before starting.

# ── Required secrets ──────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
AGENT_SHARED_SECRET=
MONGODB_URI=mongodb://localhost:27017/multi-agent-chatbot
FRONTEND_URL=http://localhost:3002

# ── Groq API (required) ───────────────────────────────────────────────────────
# Free tier — get your key at https://console.groq.com → API Keys
# No GPU or local model downloads needed.
GROQ_API_KEY=gsk_your_key_here

# ── Optional ──────────────────────────────────────────────────────────────────
# Redis for persistent rate limiting (falls back to in-memory if not set)
REDIS_URL=redis://localhost:6379

# ── Manager Configuration ─────────────────────────────────────────────────────
MANAGER_PORT=3000
MANAGER_MODEL=llama-3.1-8b-instant

# Agent Ports (3001 reserved for frontend)
AGENT_1_PORT=3005
AGENT_2_PORT=3006
AGENT_3_PORT=3007
AGENT_4_PORT=3008

# Groq model per agent — optimised for debate/critique quality
# Agent 1: deepseek-r1 chain-of-thought (devil's advocate challenger)
# Agent 2: qwen3-32b structured analyst (evidence auditor)
# Agent 3: deepseek-r1-qwen reasoning scout (edge-case finder, faster/cheaper)
# Agent 4: llama-3.3-70b specialist (technical judge + synthesis)
AGENT_1_MODEL=deepseek-r1-distill-llama-70b
AGENT_2_MODEL=qwen/qwen3-32b
AGENT_3_MODEL=deepseek-r1-distill-qwen-32b
AGENT_4_MODEL=llama-3.3-70b-versatile

# Model used for JSON-mode challenge/defense generation in debate phase
DEBATE_CHALLENGE_MODEL=qwen/qwen3-32b

# Summarizer uses a small fast model
SUMMARIZER_MODEL=llama-3.1-8b-instant

# Timeout Settings (ms) — Groq responds in <2s typically, 30s is generous
AGENT_TIMEOUT=30000
REQUEST_TIMEOUT=30000

# WebSocket Settings
WEBSOCKET_PING_TIMEOUT=600000
WEBSOCKET_PING_INTERVAL=30000

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# Frontend
FRONTEND_PORT=3002

# ── Docker agent routing (override for container-to-container networking) ─────
# Set automatically in docker-compose.yml; only needed for custom deployments
# AGENT_1_URL=http://agent-llama3:3005
# AGENT_2_URL=http://agent-mistral:3006
# AGENT_3_URL=http://agent-phi3:3007
# AGENT_4_URL=http://agent-qwen:3008

# ── OpenTelemetry (optional) ──────────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
